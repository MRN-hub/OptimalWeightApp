<Window x:Class="OptimalWeightApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вычисление оптимального веса человека"
        Height="420" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <!-- Главный контейнер с фоновым градиентом -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F0F4F8" Offset="0"/>
            <GradientStop Color="#DCE8F0" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <!-- Основной контейнер -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Поля ввода -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопка -->
            <RowDefinition Height="Auto"/>
            <!-- Результаты -->
            <RowDefinition Height="Auto"/>
            <!-- Сообщение об ошибке -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок приложения -->
        <TextBlock Grid.Row="0"
                   Text="Вычисление оптимального веса человека"
                   FontSize="16" FontWeight="Bold"
                   Foreground="#1A5276"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="0,0,0,16"/>

        <!-- Панель ввода данных -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="6" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <!-- Поле: Рост -->
                    <RowDefinition Height="Auto"/>
                    <!-- Поле: Вес -->
                    <RowDefinition Height="Auto"/>
                    <!-- Пол -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Метка и поле ввода роста -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Рост (см):"
                           VerticalAlignment="Center"
                           Margin="0,0,8,10"
                           FontWeight="SemiBold"/>
                <!-- TextBox для ввода роста; диапазон 130–220 -->
                <TextBox x:Name="HeightTextBox"
                         Grid.Row="0" Grid.Column="1"
                         Margin="0,0,0,10"
                         Padding="6,4"
                         FontSize="14"
                         BorderBrush="#2874A6"
                         BorderThickness="1.5"
                         AutomationProperties.Name="HeightInput"/>

                <!-- Метка и поле ввода веса -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Вес (кг):"
                           VerticalAlignment="Center"
                           Margin="0,0,8,10"
                           FontWeight="SemiBold"/>
                <!-- TextBox для ввода веса; диапазон 40–170 -->
                <TextBox x:Name="WeightTextBox"
                         Grid.Row="1" Grid.Column="1"
                         Margin="0,0,0,10"
                         Padding="6,4"
                         FontSize="14"
                         BorderBrush="#2874A6"
                         BorderThickness="1.5"
                         AutomationProperties.Name="WeightInput"/>

                <!-- Метка выбора пола -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Пол:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontWeight="SemiBold"/>

                <!-- Группа RadioButton для выбора пола -->
                <StackPanel Grid.Row="2" Grid.Column="1"
                            Orientation="Horizontal">
                    <!-- RadioButton: Мужчина (выбран по умолчанию) -->
                    <RadioButton x:Name="MaleRadioButton"
                                 Content="Мужчина"
                                 IsChecked="True"
                                 Margin="0,0,16,0"
                                 FontSize="13"
                                 AutomationProperties.Name="MaleOption"/>
                    <!-- RadioButton: Женщина -->
                    <RadioButton x:Name="FemaleRadioButton"
                                 Content="Женщина"
                                 FontSize="13"
                                 AutomationProperties.Name="FemaleOption"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопка запуска расчёта -->
        <Button x:Name="CalculateButton"
                Grid.Row="2"
                Content="Вычислить"
                Click="CalculateButton_Click"
                Height="40"
                FontSize="14"
                FontWeight="Bold"
                Foreground="White"
                Margin="0,0,0,12"
                Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2874A6" Offset="0"/>
                    <GradientStop Color="#1A5276" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Панель отображения результатов -->
        <Border Grid.Row="3"
                x:Name="ResultPanel"
                Background="White"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="6" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Метка оптимального веса -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Оптимальный вес:"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <!-- Значение оптимального веса -->
                <TextBlock x:Name="OptimalWeightText"
                           Grid.Row="0" Grid.Column="1"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#1A5276"
                           Margin="0,0,0,6"
                           AutomationProperties.Name="OptimalWeightResult"/>

                <!-- Метка сравнительной характеристики -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Характеристика:"
                           FontWeight="SemiBold"/>
                <!-- Значение сравнительной характеристики -->
                <TextBlock x:Name="CharacteristicText"
                           Grid.Row="1" Grid.Column="1"
                           FontSize="14"
                           FontWeight="Bold"
                           AutomationProperties.Name="CharacteristicResult"/>
            </Grid>
        </Border>

        <!-- TextBlock для вывода сообщений об ошибках -->
        <TextBlock x:Name="ErrorText"
                   Grid.Row="4"
                   Foreground="Red"
                   FontSize="12"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Visibility="Collapsed"
                   AutomationProperties.Name="ErrorMessage"/>
    </Grid>
</Window>
